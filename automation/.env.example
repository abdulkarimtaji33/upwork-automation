# ── Required ──────────────────────────────────────────────────────────────────

# Your OpenAI API key (used for GPT-4o-mini analysis + proposal generation)
OPENAI_API_KEY=sk-...

# Gmail address you're sending FROM (must match the App Password below)
EMAIL_FROM=yourname@gmail.com

# Gmail App Password (NOT your regular Gmail password)
# Generate at: https://myaccount.google.com/apppasswords
# (requires 2FA to be enabled on your Google account)
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── Optional ──────────────────────────────────────────────────────────────────

# Who to send the emails TO (default: abdulkareemmain@gmail.com)
EMAIL_TO=abdulkareemmain@gmail.com

# URL of the upwork-bridge server (default: http://127.0.0.1:9877)
BRIDGE_URL=http://127.0.0.1:9877

# Cron schedule — default is every 5 minutes
CRON_SCHEDULE=*/5 * * * *

# Path to file that tracks already-seen job UIDs (prevents duplicate emails)
# SEEN_FILE=C:\n8n\data\seen_jobs.json
